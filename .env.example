# ── AWS ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1
S3_BUCKET=your-video-bucket-name

# ── CloudFront (optional — comment out to use presigned S3 URLs instead) ───
CLOUDFRONT_URL=https://dXXXXXXXXXXXX.cloudfront.net

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/videoplatform
POSTGRES_PASSWORD=changeme

# ── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret
DEBUG=false
